NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
MAPBOX_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Struere Agent Platform (https://api.struere.dev) ---
# Operator co-pilot + durable agent runtime. Deploy your agent with the
# Struere CLI, then set STRUERE_AGENT_SLUG below so /api/struere/chat
# routes to it. Without it, Argus still works (Gemini handles agent0).
STRUERE_API_KEY=
STRUERE_AGENT_SLUG=argus-ops
STRUERE_ROUTER_SLUG=

# --- Defensive intelligence (def/acc layer) ---
# GDELT 2.0 is public, no key. Overpass is OSM, no key. Both used by
# /api/intel/gdelt and /api/intel/overpass to enrich every case with
# real-world context (news events nearby + critical infrastructure).
INTEL_GDELT_RADIUS_KM=80
INTEL_OVERPASS_RADIUS_M=4000
INTEL_OVERPASS_ENDPOINT=https://overpass-api.de/api/interpreter
PROVENANCE_GEMINI_ENABLED=true

# --- Social OSINT (Ghost.social — adapted from auto-social engine) ---
# Searches public, indexed social posts for missing-person sightings.
# Set ONE of these for reliable indexing (DuckDuckGo fallback often
# gets anomaly-modal'd from datacenter IPs).
#   Brave Search API: free tier, https://api.search.brave.com/app/dashboard
#   Serper.dev:       free tier, https://serper.dev
BRAVE_SEARCH_API_KEY=
SERPER_API_KEY=
# Per-source max requests/second across SERPs (default 1). Crank up
# for long sweeps if your key has more headroom.
OSINT_RATE_RPS=1
# Nitter mirror used to harvest X/Twitter replies without an API key.
NITTER_HOST=https://nitter.net
NEXT_PUBLIC_DEMO_WHATSAPP_NUMBER=3054879364
DEMO_WHATSAPP_NUMBER=3054879364
RESEND_API_KEY=
RESEND_FROM="ARGUS <onboarding@resend.dev>"
AUTHORITY_ALERT_EMAIL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
FACEBOOK_ENABLED=true
FACEBOOK_GRAPH_VERSION=v20.0
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_TARGET_IMAGE_URL=
FACEBOOK_TARGET_POST_URL=
FACEBOOK_TARGET_PROFILE_URL=
FACEBOOK_TARGET_NAME=
FACEBOOK_TARGET_GPS_LAT=10.4236
FACEBOOK_TARGET_GPS_LON=-75.5508
FACEBOOK_TARGET_PLACE=Cartagena
MINIMAX_ENABLED=false
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_TTS_MODEL=speech-2.8-turbo
MINIMAX_VIDEO_MODEL=MiniMax-Hailuo-2.3-Fast
MINIMAX_VIDEO_DURATION=6
MINIMAX_VIDEO_RESOLUTION=768P
# Vision model used by /api/search to compare portraits against candidate photos.
# When MINIMAX_ENABLED=true and the key works, MiniMax-VL is primary; Gemini is fallback.
MINIMAX_VISION_MODEL=MiniMax-VL-01

# Search thresholds. A "match" row is created when confidence >= SEARCH_MIN_CONFIDENCE.
# When confidence >= FOUND_NOTIFY_THRESHOLD, /api/publish-found fires automatically:
# new "ENCONTRADO" Facebook post + email to authorities. Sent once per case.
SEARCH_MIN_CONFIDENCE=0.55
FOUND_NOTIFY_THRESHOLD=0.75

ELEVENLABS_API_KEY=
ELEVENLABS_API_KEY_2=
ELEVENLABS_API_KEY_3=
ELEVENLABS_API_KEY_4=
ELEVENLABS_API_KEYS=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=
NEXT_PUBLIC_SIMLI_API_KEY=
NEXT_PUBLIC_SIMLI_FACE_ID=

# --- LiveKit (realtime voice intake) ---
# LiveKit Cloud project: https://cloud.livekit.io → Settings → Keys.
# The browser joins a room with a token from /api/livekit/token; the agent
# worker (agent-worker/) joins the same room and runs Gemini Live.
# NOTE: set BOTH url vars to the same wss:// value — the browser/token route
# reads NEXT_PUBLIC_LIVEKIT_URL, the worker CLI reads LIVEKIT_URL.
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Gemini Live realtime model used by the voice agent worker.
GOOGLE_REALTIME_MODEL=gemini-2.0-flash-live-001
# The worker reuses GEMINI_API_KEY above for the realtime session.

SUPABASE_ANON_KEY=
SUPABASE_PORTRAITS_BUCKET=portraits
